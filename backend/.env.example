# ============================================================
# Backend .env - FastAPI application configuration
# Copy to .env and fill in real values (never commit .env!)
# ============================================================

# ---- JWT ----
SECRET_KEY=change_me_very_secret_key
ACCESS_TOKEN_EXPIRE_MINUTES=2440

# ---- MySQL (Docker service name = 'mysql') ----
DB_USER=homepage_user
DB_PASSWORD=change_me_db
DB_HOST=mysql
DB_PORT=3306
DB_NAME=homepage_db

# DB connection pool
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_CONNECT_TIMEOUT=10

# ---- Minio ----
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_minio
MINIO_BUCKET=homepage
MINIO_SECURE=false

# ---- Email (optional) ----
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_email_password
EMAIL_FROM=your_email@gmail.com
EMAIL_TO_ADMIN=admin@example.com
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
