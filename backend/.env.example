# =============================================================================
# Example .env file for the refactored backend (src)
# Copy to .env and fill in production values
# =============================================================================

# ── App ──
APP_NAME="Homepage API"
DEBUG=false
ROOT_PATH=/api
# Comma-separated allowed CORS origins
ALLOWED_ORIGINS=["http://localhost:3000","https://www.m4rkus28.de"]

# ── PostgreSQL ──
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=homepage
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# ── MinIO / S3 ──
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=homepage
MINIO_SECURE=false
MINIO_PRESIGNED_EXPIRY=3600
# Public URL for presigned URLs (browser-accessible). Leave empty for internal.
# MINIO_PUBLIC_URL=https://cdn.example.com

# ── Auth (shared secret for NextJS ↔ FastAPI) ──
AUTH_INTERNAL_SHARED_SECRET=change-me-to-a-real-secret-in-production
AUTH_ALGORITHM=HS256
AUTH_TOKEN_EXPIRE_MINUTES=60

# ── Admin Seed ──
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# ── Email (aiosmtplib) ──
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_email_password
EMAIL_FROM=your_email@gmail.com
EMAIL_TO_ADMIN=admin@example.com
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false

# ── IP Geolocation (IPinfo) ──
# Optional. Without a token, IPinfo still works at a lower rate limit.
IPINFO_TOKEN=

# ── AI Translation (Google Gemini via google-adk) ──
# The ADK client reads GOOGLE_API_KEY from the process environment. The backend
# also mirrors it from this value at startup, but in Docker it is injected via
# env_file, so just set it here.
TRANSLATION_ENABLED=false
TRANSLATION_INTERVAL_MINUTES=1
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=FALSE
