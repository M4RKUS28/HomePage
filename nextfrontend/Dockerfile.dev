FROM node:20-alpine

WORKDIR /app

# Install dependencies first (cached layer)
COPY package.json package-lock.json* ./
RUN npm install

# Copy only the static config files needed at build time.
# src/, public/, and all config files are mounted via volumes at runtime.
#COPY next.config.mjs postcss.config.mjs jsconfig.json eslint.config.mjs ecosystem.config.js ./

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"
ENV NEXT_TELEMETRY_DISABLED=1

CMD ["npm", "run", "dev"]
