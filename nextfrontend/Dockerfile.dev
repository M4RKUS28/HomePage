FROM node:20-alpine

WORKDIR /app

# Install dependencies first (cached layer)
COPY package.json package-lock.json* ./
RUN npm install

# Copy all config files (next.config.mjs, postcss.config.mjs, jsconfig.json, etc.)
# src/ and public/ will be overridden by volume mounts at runtime
COPY . .

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"
ENV NEXT_TELEMETRY_DISABLED=1

CMD ["npm", "run", "dev"]
