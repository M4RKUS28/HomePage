# ============================================================
# Root .env – Docker Compose variable substitution
# Copy to .env and fill in real values (never commit .env!)
# ============================================================

# ---- MySQL (used by the 'mysql' Docker service) ----
# Root password for the MySQL container
MYSQL_ROOT_PASSWORD=change_me_root

# Application database credentials (must match backend/.env)
DB_USER=homepage_user
DB_PASSWORD=change_me_db
DB_NAME=homepage_db

# ---- Minio ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio

# ---- Next.js / PM2 ----
PM2_INSTANCES=2
