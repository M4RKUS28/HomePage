# ============================================================
# Root .env – Docker Compose variable substitution
# Used by docker-compose.neu.yml (PostgreSQL + Redis + MinIO)
# Copy to .env and fill in real values (never commit .env!)
# ============================================================

# ── PostgreSQL ──
DB_USER=homepage_user
DB_PASSWORD=change_me_db
DB_NAME=homepage_db

# ── MinIO ──
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio

# ── Auth (shared between NextJS ↔ FastAPI) ──
AUTH_INTERNAL_SHARED_SECRET=change-me-to-a-real-secret-in-production

# ── NextJS iron-session encryption key (min. 32 chars) ──
SESSION_SECRET=change-me-iron-session-secret-32-chars-min

# ── Next.js / PM2 ──
PM2_INSTANCES=2
