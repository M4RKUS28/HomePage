# =============================================================================
# .env.example — copy to .env and fill in real values (never commit .env!)
#
# This is the ONLY env file. It is consumed by:
#   - docker compose variable substitution (docker-compose.yml + deploy/)
#   - the backend container via env_file (FastAPI / pydantic-settings)
#   - the frontend container via explicit environment: entries in compose
#
# On the server: clone the repo, create this one .env at the repo root,
# then run deploy/start.sh.
# =============================================================================

# ── Docker Hub (prod image pulls, deploy/docker-compose.prod.yml) ──
DOCKERHUB_USERNAME=yourdockerhubname

# ── PostgreSQL ──
DB_USER=homepage_user
DB_PASSWORD=change_me_db
DB_NAME=homepage_db
DB_HOST=postgres
DB_PORT=5432
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# ── MinIO / S3 ──
# ROOT_* configures the MinIO server, ACCESS/SECRET is what the backend uses
# (keep them in sync unless you create a dedicated service account).
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_minio
MINIO_BUCKET=homepage
MINIO_SECURE=false
MINIO_PRESIGNED_EXPIRY=3600
# Browser-reachable base URL for presigned URLs (dev: via nginx on :8457)
MINIO_PUBLIC_URL=http://localhost:8457/minio

# ── Auth: NextJS ↔ FastAPI internal JWT (MUST be identical on both sides) ──
AUTH_INTERNAL_SHARED_SECRET=change-me-to-a-real-secret-in-production

# ── NextJS session encryption key (min. 32 chars) ──
SESSION_SECRET=change-me-iron-session-secret-32-chars-min

# ── NextJS Auth.js base URL ──
# dev:  http://localhost:8457
# prod: https://www.m4rkus28.de
AUTH_URL=http://localhost:8457

# ── Next.js / PM2 (number of PM2 workers in the frontend container) ──
PM2_INSTANCES=2

# ── Backend app ──
APP_NAME="Homepage API"
DEBUG=false
ROOT_PATH=/api
# JSON array of allowed CORS origins
ALLOWED_ORIGINS=["http://localhost:3000","https://www.m4rkus28.de"]

# ── Admin Seed (created on first backend startup) ──
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_admin

# ── Email (aiosmtplib) ──
EMAIL_ENABLED=false
EMAIL_HOST=smtp.example.com
EMAIL_PORT=465
EMAIL_USERNAME=info@example.com
EMAIL_PASSWORD=change_me_email
EMAIL_FROM=info@example.com
EMAIL_TO_ADMIN=admin@example.com
EMAIL_USE_TLS=false
EMAIL_USE_SSL=true

# ── IP Geolocation (IPinfo, optional — works without token at lower rate) ──
# IPINFO_TOKEN=

# ── AI Translation (Google Gemini) ──
TRANSLATION_ENABLED=false
# TRANSLATION_INTERVAL_MINUTES=1
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# ── BMW Job Notifier (standalone script, backend/bmw_job_notifier.py) ──
SKIP_VOLLZEIT=true
SHOW_JOB_ID=false
SHOW_STANDORT=false
SHOW_UNTERNEHMEN=false
