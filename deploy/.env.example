# =============================================================================
# deploy/.env.example — production template for https://www.m4rkus28.de
#
# On the server, copy this to the REPO ROOT as `.env` (deploy/docker-compose.
# prod.yml reads ../.env):
#
#   cp deploy/.env.example .env
#   nano .env        # replace every CHANGE_ME
#   deploy/start.sh
#
# Generate strong secrets with:  openssl rand -hex 32
# Never commit the filled-in .env!
# =============================================================================

# ── Docker Hub (prod image pulls) ──
DOCKERHUB_USERNAME=m4rkus28

# ── PostgreSQL ──
DB_USER=homepage_user
DB_PASSWORD=CHANGE_ME_openssl_rand_hex_24
DB_NAME=homepage_db
DB_HOST=postgres
DB_PORT=5432
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# ── MinIO / S3 ──
# ROOT_* configures the MinIO server, ACCESS/SECRET is what the backend uses
# (keep them in sync unless you create a dedicated service account).
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_openssl_rand_hex_24
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_same_as_root_password_or_service_account
MINIO_BUCKET=homepage
MINIO_SECURE=false
MINIO_PRESIGNED_EXPIRY=3600
# Browser-reachable base URL for presigned URLs (nginx proxies /minio)
MINIO_PUBLIC_URL=https://www.m4rkus28.de/minio

# ── Auth: NextJS ↔ FastAPI internal JWT (MUST be identical on both sides) ──
AUTH_INTERNAL_SHARED_SECRET=CHANGE_ME_openssl_rand_hex_32

# ── NextJS session encryption key (min. 32 chars) ──
SESSION_SECRET=CHANGE_ME_openssl_rand_hex_32

# ── NextJS Auth.js base URL ──
AUTH_URL=https://www.m4rkus28.de

# ── Next.js / PM2 (number of PM2 workers in the frontend container) ──
PM2_INSTANCES=2

# ── Backend app ──
APP_NAME="Homepage API"
DEBUG=false
ROOT_PATH=/api
# JSON array of allowed CORS origins
ALLOWED_ORIGINS=["https://www.m4rkus28.de","https://m4rkus28.de"]

# ── Admin Seed (created on first backend startup) ──
ADMIN_USERNAME=admin
ADMIN_EMAIL=info@m4rkus28.de
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# ── Email (aiosmtplib, Strato: SSL on port 465) ──
EMAIL_ENABLED=true
EMAIL_HOST=smtp.strato.de
EMAIL_PORT=465
EMAIL_USERNAME=info@m4rkus28.de
EMAIL_PASSWORD=CHANGE_ME_mailbox_password
EMAIL_FROM=info@m4rkus28.de
EMAIL_TO_ADMIN=CHANGE_ME_your_notification_address
EMAIL_USE_TLS=false
EMAIL_USE_SSL=true

# ── IP Geolocation (IPinfo, optional — works without token at lower rate) ──
# IPINFO_TOKEN=

# ── AI Translation (Google Gemini) ──
TRANSLATION_ENABLED=true
# TRANSLATION_INTERVAL_MINUTES=1
GOOGLE_API_KEY=CHANGE_ME_gemini_api_key
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# ── BMW Job Notifier (standalone script, backend/bmw_job_notifier.py) ──
SKIP_VOLLZEIT=true
SHOW_JOB_ID=false
SHOW_STANDORT=false
SHOW_UNTERNEHMEN=false
